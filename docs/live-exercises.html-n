<main class="main"><div id="content" class="pretext-content"><section class="chapter" id="live-exercises"><h2 class="heading">
<span class="type">Chapter</span> <span class="codenumber">4</span> <span class="title">Live Exercises</span>
</h2>
<p id="p-55">This is where the live WeBWorK problems would go and where they are coded into the project. PreTeXt currently doesn't know what to do with the <code class="code-inline tex2jax_ignore">var</code> elements, so they don't appear properly. Here is some math <span class="process-math">\(y=x^2\text{.}\)</span></p>
<section class="exercises" id="exercises-1"><h3 class="heading hide-type">
<span class="type">Exercises</span> <span class="codenumber"></span> <span class="title">Exercises</span>
</h3>
<div class="runestone">
<div data-component="fillintheblank" class="fillintheblank" style="visibility: hidden;" id="solve-equation"><script type="application/json">{
"problemHtml": "<p id=\"p-56\">Solve the equation<\/p><div class=\"displaymath process-math\" data-contains-math-knowls=\"\">\n\\begin{equation*}\n[%= theFunction.toTeX() %]=0\n\\end{equation*}\n<\/div><p class=\"continuation\">to get the value of <span class=\"process-math\">\\(x\\text{.}\\)<\/span><\/p><p id=\"p-57\"><span class=\"process-math\">\\(x = \\)<\/span> <input types=\"text\" name=\"solution\" \/><\/p>",
"blankNames": {"solution": 0},
"dyn_vars": "v._menv = new BTM({'rand': rand});\nv.m = v._menv.addMathObject(\"m\", \"number\", v._menv.generateRandom(\"discrete\", { min:-4, max:5, by:1, nonzero:true})\n);\nv.b = v._menv.addMathObject(\"b\", \"number\", v._menv.generateRandom(\"discrete\", { min:-10, max:10, by:1, nonzero:false})\n);\nv.negB = v._menv.addMathObject(\"negB\", \"number\", v._menv.parseExpression(\"-{{b}}\", \"number\"));\nv.theFunction = v._menv.addMathObject(\"theFunction\", \"formula\", v._menv.parseExpression(\"{{m}}*x+{{b}}\").reduce());\nv.theAnswer = v._menv.addMathObject(\"theAnswer\", \"formula\", v._menv.parseExpression(\"-{{b}}\/{{m}}\").reduce());\nv.types = [v._menv.getParser()];\nv.afterContentRender = function() {\n};\n",
"feedbackArray": [[{"solution_code": "function() {\n    var testResults = new Array();\n    testResults[0] = _menv.compareExpressions(theAnswer, solution);\n    return (testResults[0]);\n}()", "feedback": "Correct!"}, {"solution_code": "function() {\n    var testResults = new Array();\n    testResults[0] = _menv.compareExpressions(_menv.parseExpression(\"{{b}}\/{{m}}\").reduce(), solution);\n    return (testResults[0]);\n}()", "feedback": "Error with signs while isolating x"}, {"feedback": "Incorrect. Try again."}]]
}</script></div>
</div>
<div class="runestone">
<div data-component="fillintheblank" class="fillintheblank" style="visibility: hidden;" id="find-derivatives"><script type="application/json">{
"problemHtml": "<p id=\"p-59\">Consider the function <span class=\"process-math\">\\(f(x)=[%= formula.toTeX() %]\\text{.}\\)<\/span> Find <span class=\"process-math\">\\(f'(x)\\)<\/span> and <span class=\"process-math\">\\(f''(x)\\text{.}\\)<\/span><\/p><p id=\"p-60\"><span class=\"process-math\">\\(f'(x) = \\)<\/span> <input types=\"text\" name=\"firstD\" \/> and <span class=\"process-math\">\\(f''(x)=\\)<\/span> <input types=\"text\" name=\"secondD\" \/><\/p>",
"blankNames": {"firstD": 0, "secondD": 1},
"dyn_vars": "v._menv = new BTM({'rand': rand});\nv.a = v._menv.addMathObject(\"a\", \"number\", v._menv.generateRandom(\"discrete\", { min:-4, max:5, by:1, nonzero:true})\n);\nv.n = v._menv.addMathObject(\"n\", \"number\", v._menv.generateRandom(\"discrete\", { min:2, max:5, by:1, nonzero:false})\n);\nv.b = v._menv.addMathObject(\"b\", \"number\", v._menv.generateRandom(\"discrete\", { min:-10, max:10, by:1, nonzero:true})\n);\nv.formula = v._menv.addMathObject(\"formula\", \"formula\", v._menv.parseExpression(\"{{a}}*x^{{n}}+{{b}}\").reduce());\nv.correctD1 = v._menv.addMathObject(\"correctD1\", \"formula\", v._menv.parseExpression(\"({{a}}*{{n}})*x^({{n}}-1)\").reduce());\nv.correctD2 = v._menv.addMathObject(\"correctD2\", \"formula\", v._menv.parseExpression(\"({{a}}*{{n}}*({{n}}-1))*x^({{n}}-2)\").reduce());\nv.types = [v._menv.getParser(), v._menv.getParser()];\nv.afterContentRender = function() {\n};\n",
"feedbackArray": [[{"solution_code": "function() {\n    return _menv.compareExpressions(correctD1, firstD);\n}()", "feedback": "Correct."}, {"solution_code": "function() {\n    var testResults = new Array();\n    testResults[0] = _menv.compareExpressions(correctD2, firstD);\n    return (testResults[0]);\n}()", "feedback": "You confused which derivative is which."}, {"feedback": "Incorrect. Try again."}], [{"solution_code": "function() {\n    return _menv.compareExpressions(correctD2, secondD);\n}()", "feedback": "Correct."}, {"solution_code": "function() {\n    var testResults = new Array();\n    testResults[0] = _menv.compareExpressions(correctD1, secondD);\n    return (testResults[0]);\n}()", "feedback": "You confused which derivative is which."}, {"feedback": "Incorrect. Try again."}]]
}</script></div>
</div>
<div class="runestone">
<div data-component="fillintheblank" class="fillintheblank" style="visibility: hidden;" id="function-tangent-line"><script type="application/json">{
"problemHtml": "<p id=\"p-62\">Find the equation of the tangent line to<\/p><div class=\"displaymath process-math\" data-contains-math-knowls=\"\">\n\\begin{equation*}\nf(x)=[%= fFunc.toTeX() %]\n\\end{equation*}\n<\/div><p class=\"continuation\">at the value <span class=\"process-math\">\\(x=[%= x0.toTeX() %]\\text{.}\\)<\/span><\/p><p id=\"p-63\"><span class=\"process-math\">\\(y=\\)<\/span> <input types=\"text\" name=\"stuTangent\" \/><\/p><div class=\"jxgbox\" id=\"[%=divid%]-graph\" style=\"width:300px; height:300px;graph\" \/>",
"blankNames": {"stuTangent": 0},
"dyn_vars": "v._menv = new BTM({'rand': rand});\nv.a = v._menv.addMathObject(\"a\", \"number\", v._menv.generateRandom(\"discrete\", { min:-4, max:5, by:1, nonzero:true})\n);\nv.b = v._menv.addMathObject(\"b\", \"number\", v._menv.generateRandom(\"discrete\", { min:-10, max:10, by:1, nonzero:false})\n);\nv.c = v._menv.addMathObject(\"c\", \"number\", v._menv.generateRandom(\"discrete\", { min:-10, max:10, by:1, nonzero:true})\n);\nv.x0 = v._menv.addMathObject(\"x0\", \"number\", v._menv.generateRandom(\"discrete\", { min:-3, max:3, by:1, nonzero:false})\n);\nv.fFunc = v._menv.addMathObject(\"fFunc\", \"formula\", v._menv.parseExpression(\"{{a}}*x^2+{{b}}*x+{{c}}\").reduce());\nv.fPrime = v._menv.addMathObject(\"fPrime\", \"formula\", v.fFunc.derivative(\"x\"));\nv.y0 = v._menv.addMathObject(\"y0\", \"number\", v._menv.evaluateMathObject(v.fFunc, \"number\", {\"x\": v.x0.value()}).reduce());\nv.m = v._menv.addMathObject(\"m\", \"number\", v._menv.evaluateMathObject(v.fPrime, \"number\", {\"x\": v.x0.value()}).reduce());\nv.tangentFunc = v._menv.addMathObject(\"tangentFunc\", \"formula\", v._menv.parseExpression(\"{{m}}*(x-{{x0}})+{{y0}}\").reduce());\nv.errorTangent1 = v._menv.addMathObject(\"errorTangent1\", \"formula\", v._menv.parseExpression(\"{{fPrime}}*(x-{{x0}})+{{y0}}\").reduce());\nv.types = [v._menv.getParser()];\nv.afterContentRender = function() {\n{\nlet curBoard;\ncurBoard = v.jsx_graph = JXG.JSXGraph.initBoard(v.divid+\"-graph\", {boundingbox: [-5,50,5,-50], axis:true, drag:{enabled:false}, showNavigation:false});\n{\nlet formulaObj = v.fFunc;\ncurBoard.create('functiongraph', [\nfunction(x){ return formulaObj.evaluate({\"x\": x}); },\n-5, 5]);\n}\ncurBoard.create('point', [v.x0.value(), v.y0.value()],  {fixed:true, visible:true});\n}\n};\n",
"feedbackArray": [[{"solution_code": "function() {\n    var testResults = new Array();\n    testResults[0] = _menv.compareExpressions(tangentFunc, stuTangent);\n    return (testResults[0]);\n}()", "feedback": "Correct!"}, {"solution_code": "function() {\n    var testResults = new Array();\n    testResults[0] = _menv.compareExpressions(errorTangent1, stuTangent);\n    return (testResults[0]);\n}()", "feedback": "Don't forget to evaluate the derivative at the point."}, {"solution_code": "function() {\n    var testResults = new Array();\n    testResults[0] = _menv.compareExpressions(fPrime, stuTangent);\n    return (testResults[0]);\n}()", "feedback": "The derivative itself is not the same as the tangent line."}, {"feedback": "Try again."}]]
}</script></div>
</div>
<div class="runestone">
<div data-component="fillintheblank" class="fillintheblank" style="visibility: hidden;" id="function-decomposition"><script type="application/json">{
"problemHtml": "<p id=\"p-65\">Consider the function<\/p><div class=\"displaymath process-math\" data-contains-math-knowls=\"\">\n\\begin{equation*}\nh(x)=[%= composition.toTeX() %]\\text{.}\n\\end{equation*}\n<\/div><p class=\"continuation\">Find two nontrivial functions <span class=\"process-math\">\\(f(x)\\)<\/span> and <span class=\"process-math\">\\(g(x)\\)<\/span> so that <span class=\"process-math\">\\(h(x) = f(g(x))\\text{.}\\)<\/span><\/p><p id=\"p-66\"><span class=\"process-math\">\\(f(x) = \\)<\/span> <input types=\"text\" name=\"fGiven\" \/> and <span class=\"process-math\">\\(g(x)=\\)<\/span> <input types=\"text\" name=\"gGiven\" \/><\/p>",
"blankNames": {"fGiven": 0, "gGiven": 1},
"dyn_vars": "v._menv = new BTM({'rand': rand});\nv.a = v._menv.addMathObject(\"a\", \"number\", v._menv.generateRandom(\"discrete\", { min:-4, max:5, by:1, nonzero:true})\n);\nv.n = v._menv.addMathObject(\"n\", \"number\", v._menv.generateRandom(\"discrete\", { min:2, max:5, by:1, nonzero:false})\n);\nv.b = v._menv.addMathObject(\"b\", \"number\", v._menv.generateRandom(\"discrete\", { min:-10, max:10, by:1, nonzero:true})\n);\nv.c = v._menv.addMathObject(\"c\", \"number\", v._menv.generateRandom(\"discrete\", { min:-4, max:5, by:1, nonzero:true})\n);\nv.d = v._menv.addMathObject(\"d\", \"number\", v._menv.generateRandom(\"discrete\", { min:-10, max:10, by:1, nonzero:true})\n);\nv.outerFormula = v._menv.addMathObject(\"outerFormula\", \"formula\", v._menv.parseExpression(\"{{a}}*x^{{n}}+{{b}}\").reduce());\nv.innerFormula = v._menv.addMathObject(\"innerFormula\", \"formula\", v._menv.parseExpression(\"{{c}}*x+{{d}}\").reduce());\nv.identityFunction = v._menv.addMathObject(\"identityFunction\", \"formula\", v._menv.parseExpression(\"x\").reduce());\nv.composition = v._menv.addMathObject(\"composition\", \"formula\", v.outerFormula.compose({\"x\": v.innerFormula}).reduce());\nv.types = [v._menv.getParser(), v._menv.getParser()];\nv.afterContentRender = function() {\n};\n",
"feedbackArray": [[{"solution_code": "function() {\n    return _menv.compareExpressions(outerFormula, fGiven);\n}()", "feedback": "Correct."}, {"solution_code": "function() {\n    var testResults = new Array();\n    testResults[0] = _menv.compareExpressions(identityFunction, fGiven);\n    return (testResults[0]);\n}()", "feedback": "f(x)=x is not allowed for nontrivial compositions."}, {"solution_code": "function() {\n    var testResults = new Array();\n    testResults[0] = _menv.compareExpressions(composition, gGiven.compose({\"x\": fGiven}).reduce());\n    return (testResults[0]);\n}()", "feedback": "You have composed in the wrong order."}, {"feedback": "Try again."}], [{"solution_code": "function() {\n    return _menv.compareExpressions(innerFormula, gGiven);\n}()", "feedback": "Correct."}, {"solution_code": "function() {\n    var testResults = new Array();\n    testResults[0] = _menv.compareExpressions(identityFunction, gGiven);\n    return (testResults[0]);\n}()", "feedback": "g(x)=x is not allowed for nontrivial compositions."}, {"feedback": "Try again."}]]
}</script></div>
</div></section></section></div></main>
</div>
</body>
</html>
